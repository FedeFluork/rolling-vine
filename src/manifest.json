{
  "manifest_version": 3,
  "name": "Rolling Vine",
  "description": "Shows Amazon Vine rolling periods review risk for 30/60/90 day windows with user-triggered sync.",
  "version": "1.0.0",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "64": "assets/icon64.png",
    "96": "assets/icon96.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.amazon.com/vine/*",
    "https://www.amazon.co.uk/vine/*",
    "https://www.amazon.de/vine/*",
    "https://www.amazon.fr/vine/*",
    "https://www.amazon.it/vine/*",
    "https://www.amazon.es/vine/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/vine/*",
        "https://www.amazon.co.uk/vine/*",
        "https://www.amazon.de/vine/*",
        "https://www.amazon.fr/vine/*",
        "https://www.amazon.it/vine/*",
        "https://www.amazon.es/vine/*"
      ],
      "js": [
        "shared/core.js",
        "shared/storage.js",
        "content/vine-content.js"
      ],
      "css": [
        "content/vine-content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/assets/*.svg"
      ],
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.co.uk/*",
        "https://www.amazon.de/*",
        "https://www.amazon.fr/*",
        "https://www.amazon.it/*",
        "https://www.amazon.es/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "rolling-vine@fedefluork.dev",
      "strict_min_version": "121.0"
    }
  }
}
